NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
GATEWAY_API_KEY=local-development-key
GATEWAY_KEY_PEPPER=local-development-pepper
PROVIDER_TIMEOUT_MS=30000
DEFAULT_MAX_OUTPUT_TOKENS=512
QUOTA_RESERVATION_TTL_MS=600000
ROUTING_MAX_ATTEMPTS=3
ROUTING_RATE_LIMIT_COOLDOWN_MS=30000
ROUTING_CIRCUIT_FAILURE_THRESHOLD=3
ROUTING_CIRCUIT_OPEN_MS=30000
METRICS_ENABLED=true
METRICS_BEARER_TOKEN=local-development-metrics-key

# Iteration 8: persistent virtual-key control plane. Start PostgreSQL with
# `docker compose --profile control-plane up -d postgres` before enabling.
# DATABASE_URL=postgres://aigateway:aigateway-local@127.0.0.1:5433/aigateway
# Local-only compatibility mode. Production rejects static admin tokens unless
# the break-glass override is explicitly enabled.
# ADMIN_AUTH_MODE=static
# ADMIN_BEARER_TOKEN=local-development-admin-key-change-me
# Local Owner mode is the development default when neither static nor OIDC is configured.
# The first browser registration creates one password owner, then registration closes.
# ADMIN_AUTH_MODE=local
# ADMIN_LOCAL_ACCOUNT_FILE=.data/admin-local-owner.json
# ADMIN_LOCAL_ACCESS_TOKEN_TTL_SECONDS=900
# Production local mode additionally requires two independent 32+ character secrets:
# ADMIN_LOCAL_TOKEN_SECRET=replace-with-strong-random-signing-secret
# ADMIN_LOCAL_BOOTSTRAP_TOKEN=replace-with-one-time-deployment-bootstrap-secret
# Production OIDC resource-server mode:
# ADMIN_AUTH_MODE=oidc
# ADMIN_OIDC_ISSUER=https://identity.example.com/tenant
# ADMIN_OIDC_AUDIENCE=ai-gateway-admin
# ADMIN_OIDC_JWKS_URL=https://identity.example.com/tenant/.well-known/jwks.json
# ADMIN_OIDC_ROLE_CLAIM=groups
# ADMIN_OIDC_TENANT_CLAIM=ai_gateway_tenants
# ADMIN_OIDC_ROLE_MAP_JSON={"ai-gateway-viewers":"viewer","ai-gateway-operators":"operator","ai-gateway-admins":"admin"}
# ADMIN_OIDC_ALLOWED_ALGORITHMS=RS256
# ADMIN_OIDC_TOKEN_TYP=JWT
# ADMIN_OIDC_CLOCK_TOLERANCE_SECONDS=5
# ADMIN_OIDC_JWKS_TIMEOUT_MS=3000
# ADMIN_OIDC_JWKS_COOLDOWN_MS=30000
# ADMIN_OIDC_JWKS_CACHE_MAX_AGE_MS=600000
# Production defaults to requiring two-person rotation approval.
# ROTATION_APPROVAL_REQUIRED=true
# ROTATION_APPROVAL_TTL_MS=900000
# DATABASE_AUTO_MIGRATE=true
# CONTROL_PLANE_SEED_FROM_ENV=true
# DATABASE_POOL_MAX=10
# DATABASE_CONNECTION_TIMEOUT_MS=3000
# Optional local observability stack overrides.
# METRICS_TOKEN_FILE=./observability/secrets/metrics-token
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-local-password

# Optional in development, required in production when quota policies exist.
# REDIS_URL=redis://127.0.0.1:6380
# GATEWAY_QUOTA_POLICIES_JSON=[{"id":"tenant-default","scope":"tenant","scopeId":"local-tenant","limits":{"requestsPerMinute":60,"tokensPerMinute":10000,"maxConcurrent":5}}]

# Multi-key mode. When configured, this replaces GATEWAY_API_KEY.
# Keep the JSON on one line. Production keys and pepper must be 32+ characters.
# GATEWAY_VIRTUAL_KEYS_JSON=[{"keyId":"team-a-key","key":"aigw_replace_with_32_plus_characters","tenantId":"tenant-a","projectId":"project-a","applicationId":"app-a","allowedModels":["general","external"]}]

# Optional: configure base URL and model to register the `external` logical model.
# OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
# OPENAI_COMPAT_MODEL=gpt-4.1-mini
# API key may be omitted for trusted local providers such as development vLLM.
# OPENAI_COMPAT_API_KEY=replace-me
# OPENAI_COMPAT_LOGICAL_MODEL=external

# Optional multi-deployment mode. Secrets are referenced by environment-variable
# name so the JSON does not contain API keys. Keep JSON on one line.
# PRIMARY_PROVIDER_KEY=replace-me
# BACKUP_PROVIDER_KEY=replace-me
# OPENAI_COMPAT_DEPLOYMENTS_JSON=[{"id":"primary","logicalModel":"external","baseUrl":"https://api.openai.com/v1","providerModel":"gpt-4.1-mini","apiKeyEnv":"PRIMARY_PROVIDER_KEY","priority":1,"weight":80},{"id":"backup","logicalModel":"external","baseUrl":"https://another-provider.example/v1","providerModel":"compatible-model","apiKeyEnv":"BACKUP_PROVIDER_KEY","priority":2,"weight":20}]
