GATEWAY_API_BASE_URL=http://127.0.0.1:3000

# Browser-facing origin and server-side session settings.
ADMIN_CONSOLE_PUBLIC_ORIGIN=http://127.0.0.1:3100
ADMIN_CONSOLE_SESSION_SECRET=replace-with-at-least-32-random-characters
ADMIN_CONSOLE_SESSION_TTL_SECONDS=900

# Local Owner login is automatically discovered from the Gateway. In production,
# this must match the Gateway's server-only bootstrap token; it is never sent to the browser.
# ADMIN_LOCAL_BOOTSTRAP_TOKEN=replace-with-one-time-deployment-bootstrap-secret

# Redis is mandatory in production. Without it in development, sessions are kept
# in one Next.js process and disappear when that process restarts.
ADMIN_CONSOLE_REDIS_URL=redis://127.0.0.1:6379

# Enterprise OIDC Authorization Code + PKCE.
ADMIN_CONSOLE_OIDC_ISSUER=https://id.example.com
ADMIN_CONSOLE_OIDC_CLIENT_ID=ai-gateway-admin
ADMIN_CONSOLE_OIDC_CLIENT_SECRET=
ADMIN_CONSOLE_OIDC_REDIRECT_URI=http://127.0.0.1:3100/api/auth/callback
ADMIN_CONSOLE_OIDC_SCOPES=openid profile

# Local-only escape hatch. The route refuses to run when NODE_ENV=production.
ADMIN_CONSOLE_ALLOW_DEV_TOKEN_LOGIN=false
